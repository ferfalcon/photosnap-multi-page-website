---
import { betaInvite } from '../data/site';
import ButtonLink from './ButtonLink.astro';
---

<section class="beta-invite" aria-labelledby="beta-invite-title">
	<div class="beta-invite__content">
		<h2
			id="beta-invite-title"
			class="beta-invite__heading"
			aria-label={betaInvite.heading}
		>
			{
				betaInvite.headingLines.map((line) => (
					<span class="beta-invite__heading-line" aria-hidden="true">
						{line}
					</span>
				))
			}
		</h2>
		<ButtonLink
			href={betaInvite.cta.href}
			label={betaInvite.cta.label}
			variant="arrow"
			color="white"
		/>
	</div>
</section>

<style>
	.beta-invite {
		position: relative;
		display: grid;
		align-items: center;
		min-block-size: 18rem;
		padding-block: var(--space-800);
		background-color: var(--color-surface-inverse);
		background-image:
			linear-gradient(rgb(0 0 0 / 50%), rgb(0 0 0 / 50%)),
			url('/assets/images/shared/beta-invite-mobile.jpg');
		background-position: center;
		background-size: cover;
		color: var(--color-text-inverse);
	}

	.beta-invite::before {
		position: absolute;
		inset-block-start: 0;
		inset-inline-start: max(
			var(--layout-page-gutter),
			calc((100% - 19.375rem) / 2)
		);
		inline-size: 8rem;
		block-size: 0.375rem;
		background: var(--gradient-brand);
		content: '';
	}

	.beta-invite__content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--space-300);
		inline-size: min(calc(100% - (2 * var(--layout-page-gutter))), 19.375rem);
		margin-inline: auto;
	}

	.beta-invite__heading {
		font-size: var(--text-preset-2-size);
		font-weight: var(--font-weight-bold);
		line-height: var(--text-preset-2-line-height);
		letter-spacing: var(--text-preset-2-letter-spacing);
		text-transform: uppercase;
		text-wrap: wrap;
	}

	.beta-invite__heading-line {
		display: block;
	}

	@media (min-width: 23.4375rem) {
		.beta-invite__heading-line {
			white-space: nowrap;
		}
	}

	@media (min-width: 48rem) {
		.beta-invite {
			min-block-size: 17.5rem;
			padding-block: var(--space-800);
			background-image:
				linear-gradient(rgb(0 0 0 / 50%), rgb(0 0 0 / 50%)),
				url('/assets/images/shared/beta-invite-tablet.jpg');
		}

		.beta-invite::before {
			inset-inline-start: 0;
			inline-size: 0.375rem;
			block-size: 100%;
		}

		.beta-invite__content {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			gap: var(--space-400);
			inline-size: min(calc(100% - (2 * 2.375rem)), 68.75rem);
		}

		.beta-invite__heading {
			max-inline-size: 25rem;
			font-size: var(--text-preset-1-size);
			line-height: var(--text-preset-1-line-height);
			letter-spacing: var(--text-preset-1-letter-spacing);
		}
	}

	@media (min-width: 75rem) {
		.beta-invite {
			background-image:
				linear-gradient(rgb(0 0 0 / 50%), rgb(0 0 0 / 50%)),
				url('/assets/images/shared/beta-invite-desktop.jpg');
		}

		.beta-invite__content {
			inline-size: min(
				calc(100% - (2 * var(--layout-page-gutter))),
				var(--layout-content-max)
			);
		}
	}
</style>
