---
import { isCurrentPath, primaryNavigation } from '../data/navigation';
import { inviteCta } from '../data/site';
import ButtonLink from './ButtonLink.astro';
import Logo from './Logo.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
	<div class="site-header__inner container">
		<a
			class="site-header__brand"
			href="/"
			aria-label="Photosnap home"
			data-mobile-menu-brand
			data-mobile-menu-inert
		>
			<Logo gradientId="header-logo-gradient" />
		</a>

		<nav class="site-header__navigation" aria-label="Primary">
			<ul>
				{
					primaryNavigation.map((item) => (
						<li>
							<a
								href={item.href}
								aria-current={
									isCurrentPath(currentPath, item.href) ? 'page' : undefined
								}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="site-header__cta">
			<ButtonLink
				href={inviteCta.href}
				label={inviteCta.label}
				variant="solid"
				color="black"
			/>
		</div>

		<button
			class="site-header__menu-trigger"
			type="button"
			aria-controls="mobile-navigation"
			aria-expanded="false"
			popovertarget="mobile-navigation"
			data-mobile-menu-trigger
		>
			<span class="site-header__menu-label site-header__menu-label--open visually-hidden">
				Open menu
			</span>
			<span class="site-header__menu-label site-header__menu-label--close visually-hidden">
				Close menu
			</span>
			<img
				class="site-header__menu-icon site-header__menu-icon--open"
				src="/assets/icons/ui/menu.svg"
				alt=""
				width="20"
				height="6"
				aria-hidden="true"
			/>
			<img
				class="site-header__menu-icon site-header__menu-icon--close"
				src="/assets/icons/ui/close.svg"
				alt=""
				width="16"
				height="15"
				aria-hidden="true"
			/>
		</button>
	</div>

	<MobileMenu items={primaryNavigation} currentPath={currentPath} cta={inviteCta} />
</header>

<style>
	.site-header {
		display: flex;
		align-items: center;
		block-size: var(--layout-header-block-size);
		background: var(--color-surface);
		color: var(--color-text);
	}

	.site-header__inner {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		block-size: 100%;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		justify-self: start;
		min-block-size: 2.75rem;
		color: var(--color-text);
	}

	.site-header__navigation,
	.site-header__cta {
		display: none;
	}

	.site-header__menu-trigger {
		display: grid;
		align-items: center;
		justify-items: end;
		justify-self: end;
		inline-size: 2.75rem;
		block-size: 2.75rem;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--color-text);
		cursor: pointer;
	}

	.site-header__menu-icon {
		grid-area: 1 / 1;
		display: block;
	}

	.site-header__menu-icon--close,
	.site-header__menu-label--close {
		display: none;
	}

	:global(body:has(#mobile-navigation:popover-open)) .site-header__menu-icon--open,
	:global(body:has(#mobile-navigation:popover-open)) .site-header__menu-label--open {
		display: none;
	}

	:global(body:has(#mobile-navigation:popover-open)) .site-header__menu-icon--close {
		display: block;
	}

	:global(body:has(#mobile-navigation:popover-open)) .site-header__menu-label--close {
		display: inline;
	}

	@media (min-width: 48rem) {
		.site-header__inner {
			grid-template-columns: 1fr auto 1fr;
		}

		.site-header__navigation {
			display: block;
			grid-column: 2;
		}

		.site-header__navigation ul {
			display: flex;
			align-items: center;
			gap: var(--space-500);
			list-style: none;
		}

		.site-header__navigation a {
			display: inline-flex;
			align-items: center;
			min-block-size: 2.75rem;
			font-size: var(--text-preset-7-size);
			font-weight: var(--font-weight-bold);
			line-height: var(--text-preset-7-line-height);
			letter-spacing: var(--text-preset-7-letter-spacing);
			text-decoration: none;
		}

		.site-header__cta {
			display: block;
			grid-column: 3;
			justify-self: end;
		}

		.site-header__menu-trigger {
			display: none;
		}
	}

	@media (min-width: 48rem) and (hover: hover) {
		.site-header__navigation a:hover {
			text-decoration: underline;
			text-underline-offset: 0.25em;
		}
	}
</style>
