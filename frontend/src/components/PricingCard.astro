---
import type { PricingPlan } from '../data/types';

interface Props {
	plan: PricingPlan;
}

const { plan } = Astro.props;
---

<article
	class:list={[
		'pricing-card',
		{ 'pricing-card--featured': plan.isFeatured },
	]}
	data-pricing-card
>
	<div class="pricing-card__inner">
		<div class="pricing-card__summary">
			<h3 class="pricing-card__name">{plan.name}</h3>
			<p class="pricing-card__description">{plan.description}</p>
		</div>
		<div class="pricing-card__price-group">
			<p
				class="pricing-card__price"
				data-pricing-price
				data-monthly-price={plan.monthlyPrice}
				data-yearly-price={plan.yearlyPrice}
			>
				{plan.monthlyPrice}
			</p>
			<p
				class="pricing-card__period"
				data-pricing-period
				data-monthly-period={plan.monthlyPeriodLabel}
				data-yearly-period={plan.yearlyPeriodLabel}
			>
				{plan.monthlyPeriodLabel}
			</p>
		</div>
		<span class="pricing-card__action" aria-hidden="true">
			{plan.ctaLabel}
		</span>
	</div>
</article>

<style>
	.pricing-card {
		position: relative;
		display: grid;
		place-items: center;
		inline-size: min(100%, 19.875rem);
		min-block-size: 25.4375rem;
		background: var(--color-surface-subtle);
		color: var(--color-text);
		text-align: center;
	}

	.pricing-card--featured {
		background: var(--color-surface-inverse);
		color: var(--color-text-inverse);
	}

	.pricing-card--featured::before {
		position: absolute;
		inset-block-start: 0;
		inset-inline: 0;
		block-size: 0.375rem;
		background: var(--gradient-brand);
		content: '';
	}

	.pricing-card__inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-500);
		inline-size: min(calc(100% - 4.5rem), 15.3125rem);
	}

	.pricing-card__summary {
		display: flex;
		flex-direction: column;
		gap: var(--space-250);
	}

	.pricing-card__name {
		font-size: var(--text-preset-3-size);
		font-weight: var(--font-weight-bold);
		line-height: var(--text-preset-3-line-height);
	}

	.pricing-card__description,
	.pricing-card__period {
		font-size: var(--text-preset-5-size);
		line-height: var(--text-preset-5-line-height);
		opacity: 0.6;
	}

	.pricing-card__price-group {
		display: flex;
		flex-direction: column;
	}

	.pricing-card__price {
		font-size: var(--text-preset-1-size);
		font-weight: var(--font-weight-bold);
		line-height: var(--text-preset-1-line-height);
		letter-spacing: var(--text-preset-1-letter-spacing);
		text-transform: uppercase;
	}

	.pricing-card__action {
		display: grid;
		place-items: center;
		inline-size: 100%;
		min-block-size: 2.5rem;
		background: var(--color-surface-inverse);
		color: var(--color-text-inverse);
		font-size: var(--text-preset-7-size);
		font-weight: var(--font-weight-bold);
		line-height: var(--text-preset-7-line-height);
		letter-spacing: var(--text-preset-7-letter-spacing);
	}

	.pricing-card--featured .pricing-card__action {
		background: var(--color-surface);
		color: var(--color-text);
	}

	@media (min-width: 48rem) {
		.pricing-card {
			inline-size: min(100%, 43.0625rem);
			min-block-size: 16.875rem;
			text-align: start;
		}

		.pricing-card--featured::before {
			inset-block: 0;
			inset-inline-start: 0;
			inset-inline-end: auto;
			inline-size: 0.375rem;
			block-size: auto;
		}

		.pricing-card__inner {
			display: grid;
			grid-template-areas:
				'summary price'
				'action price';
			grid-template-columns: 16.875rem 17.375rem;
			grid-template-rows: auto 2.5rem;
			column-gap: 3.3125rem;
			row-gap: var(--space-375);
			inline-size: min(calc(100% - 5.5rem), 37.5625rem);
		}

		.pricing-card__summary {
			grid-area: summary;
		}

		.pricing-card__price-group {
			grid-area: price;
			text-align: end;
		}

		.pricing-card__action {
			grid-area: action;
		}
	}

	@media (min-width: 75rem) {
		.pricing-card {
			inline-size: 21.875rem;
			min-block-size: 25.4375rem;
			text-align: center;
		}

		.pricing-card--featured {
			min-block-size: 29.375rem;
		}

		.pricing-card--featured::before {
			inset-block-start: 0;
			inset-block-end: auto;
			inset-inline: 0;
			inline-size: auto;
			block-size: 0.375rem;
		}

		.pricing-card__inner {
			display: flex;
			gap: var(--space-500);
			inline-size: 16.875rem;
		}

		.pricing-card__price-group {
			text-align: center;
		}
	}
</style>
