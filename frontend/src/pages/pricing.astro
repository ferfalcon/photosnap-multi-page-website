---
import BetaInvite from '../components/BetaInvite.astro';
import PricingComparison from '../components/PricingComparison.astro';
import PricingPlans from '../components/PricingPlans.astro';
import SplitSection from '../components/SplitSection.astro';
import {
	billingPeriods,
	defaultBillingPeriod,
	pricingComparisonRows,
	pricingHero,
	pricingPlans,
} from '../data/pricing';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Pricing | Photosnap"
	description="Compare Photosnap plans and choose the option that fits your photography."
>
	<SplitSection
		heading={pricingHero.heading}
		body={pricingHero.body}
		image={pricingHero.image}
		theme="dark"
		imagePosition="right"
		variant="page-hero"
		headingLevel="h1"
		accent
		isLcp
	/>
	<PricingPlans
		plans={pricingPlans}
		periods={billingPeriods}
		defaultPeriod={defaultBillingPeriod}
	/>
	<PricingComparison rows={pricingComparisonRows} />
	<BetaInvite />
</BaseLayout>
