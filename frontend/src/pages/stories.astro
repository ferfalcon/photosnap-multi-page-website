---
import FeaturedStoryHero from '../components/FeaturedStoryHero.astro';
import StoryGrid from '../components/StoryGrid.astro';
import { featuredStory, stories } from '../data/stories';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Stories | Photosnap"
	description="Discover photo stories from photographers and visual storytellers around the world."
>
	<FeaturedStoryHero story={featuredStory} />
	<section aria-labelledby="all-stories-title">
		<h2 id="all-stories-title" class="visually-hidden">All stories</h2>
		<StoryGrid stories={stories} />
	</section>
</BaseLayout>
